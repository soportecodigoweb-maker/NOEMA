# =============================================================================
# NOEMA — Variables de entorno
# =============================================================================
# Copia este archivo a `.env.local` en la raíz y en cada app que lo necesite.
# Nunca commitees `.env.local` — está en `.gitignore`.

# -----------------------------------------------------------------------------
# Supabase (local development con `pnpm supabase:start`)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-start
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-start

# Para apps móviles (Expo) — mismo valor pero con prefijo EXPO_PUBLIC_
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-start

# -----------------------------------------------------------------------------
# Anthropic Claude (IA operativa — guardrails en código)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# -----------------------------------------------------------------------------
# Stripe (post-MVP)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# -----------------------------------------------------------------------------
# Resend (emails transaccionales)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxx
EMAIL_FROM=NOEMA <hola@noema.app>

# -----------------------------------------------------------------------------
# Sentry (errores en producción)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Entorno
# -----------------------------------------------------------------------------
NODE_ENV=development
