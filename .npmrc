# NOEMA monorepo — pnpm config
#
# Para Expo SDK 54 con monorepo + pnpm necesitamos hoistear TODAS las
# transitive deps porque Metro NO resuelve symlinks de .pnpm/.
# shamefully-hoist=true crea node_modules plano (como npm tradicional).
#
# Trade-off: pierdes algo del aislamiento de pnpm, pero ganas compatibilidad
# completa con Metro/Expo sin instalar peer deps manualmente.
shamefully-hoist=true
public-hoist-pattern[]=*
